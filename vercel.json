{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/api-server run build && PORT=3000 BASE_PATH=/ pnpm --filter @workspace/up-dash run build",
  "outputDirectory": "artifacts/up-dash/dist/public",
  "functions": {
    "api/index.js": {
      "maxDuration": 60
    },
    "api/[...path].js": {
      "maxDuration": 60
    },
    "api/analytics/[...path].js": {
      "maxDuration": 60
    },
    "api/auth/[...path].js": {
      "maxDuration": 60
    },
    "api/clients/[...path].js": {
      "maxDuration": 60
    },
    "api/notifications/[...path].js": {
      "maxDuration": 60
    },
    "api/saved-views/[...path].js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/extractions/hourly",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/extractions/upzero-transactional",
      "schedule": "0 3,15 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api?path=$1"
    },
    {
      "source": "/up-dash",
      "destination": "/index.html"
    },
    {
      "source": "/up-dash/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/((?!api/.*).*)",
      "destination": "/index.html"
    }
  ]
}
